{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": ["Renovate config for Node.js/TypeScript projects"],
  "extends": ["github>h13/renovate-config"],
  "packageRules": [
    {
      "matchDepTypes": ["devDependencies"],
      "groupName": "dev dependencies"
    },
    {
      "matchPackageNames": [
        "/^eslint/",
        "/^@eslint\\//",
        "/^typescript-eslint/"
      ],
      "groupName": "eslint"
    },
    {
      "matchPackageNames": ["/^prettier/", "/^@biomejs\\//"],
      "groupName": "formatter"
    },
    {
      "matchPackageNames": [
        "/^jest/",
        "/^@jest\\//",
        "/^vitest/",
        "/^@vitest\\//",
        "/^@testing-library\\//",
        "/^mocha/",
        "/^chai/",
        "/^sinon/",
        "c8",
        "nyc"
      ],
      "groupName": "testing"
    },
    {
      "matchPackageNames": ["/^@types\\//"],
      "groupName": "type definitions"
    }
  ]
}
