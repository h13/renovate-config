{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": ["Renovate config for PHP projects"],
  "extends": ["github>h13/renovate-config"],
  "packageRules": [
    {
      "matchManagers": ["composer"],
      "rangeStrategy": "update-lockfile"
    },
    {
      "matchPackageNames": ["/^phpstan\\//", "nunomaduro/larastan"],
      "groupName": "phpstan"
    },
    {
      "matchPackageNames": ["/^phpunit\\//"],
      "groupName": "phpunit"
    },
    {
      "matchPackageNames": [
        "friendsofphp/php-cs-fixer",
        "/^symplify\\//",
        "/^php-cs-fixer/"
      ],
      "groupName": "code style"
    }
  ]
}
